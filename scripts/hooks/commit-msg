#!/bin/bash
# commit-msg hook — 检查 commit message 质量
# 安装: cp this ~/.openclaw/workspace/skills/.git/hooks/commit-msg && chmod +x

MSG_FILE="$1"
MSG=$(cat "$MSG_FILE")
LEN=${#MSG}

# 检查长度
if [ "$LEN" -lt 10 ]; then
  echo ""
  echo "⚠️  Commit message 太短 ($LEN 字符)"
  echo "   建议使用 commit-message-router 生成: 说 '帮我写commit message'"
  echo ""
  # 不阻止提交，只是提醒
fi

# 检查是否符合 conventional commits 格式
if ! echo "$MSG" | head -1 | grep -qE "^(feat|fix|docs|style|refactor|test|chore|ci|perf|build|revert)(\(.+\))?: .+"; then
  echo ""
  echo "💡 Commit message 不符合 Conventional Commits 格式"
  echo "   推荐格式: type(scope): description"
  echo "   例如: feat(auth): add login validation"
  echo ""
fi
